DISCORD_TOKEN=your_discord_bot_token_here
COMMAND_PREFIX=!
BOT_STATUS=✨ anime WanaLike
DISCORD_DEFAULT_CHANNEL_ID=
NOVALIKE_AI_ROLE=Nova-Testers

API_HOST=127.0.0.1
API_PORT=9010
API_BASE_URL=http://127.0.0.1:9010
NOVALIKE_API_TOKEN=change_me_strong_random_token

# IA / Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
AI_PROVIDER=local
AI_PUBLIC_ENABLED=false
AI_ALLOWED_ROLE_IDS=
AI_ALLOWED_CHANNEL_IDS=
AI_COOLDOWN_SECONDS=60
AI_DAILY_REQUEST_LIMIT=100
AI_MAX_TOKENS=180

# WanaLike Publisher bridge
PUBLISHER_ENABLED=true
PUBLISHER_API_URL=https://publisher.wanalike.com/api
PUBLISHER_API_TOKEN=
PUBLISHER_DEFAULT_AUTHOR=NovaLike

# Pooshy / IRC bridge
POOSHY_ENABLED=true
POOSHY_API_URL=http://127.0.0.1:7000
POOSHY_API_TOKEN=
POOSHY_RELAY_ENABLED=true
POOSHY_RELAY_DISCORD_TO_IRC=false
POOSHY_RELAY_IRC_TO_DISCORD=true

# WanaFM
